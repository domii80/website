<%- include('partials/header') %>

<article class="post">
  <header class="post-header">
    <h1><%= post.title %></h1>
    <time><%= post.created_at %></time>
  </header>
  <div class="post-body">
    <%- post.body.replace(/\n/g, '<br>') %>
  </div>
  <a href="/blog" class="btn outline">&larr; Back to Blog</a>
</article>

<%- include('partials/footer') %>
